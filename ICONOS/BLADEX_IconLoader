local IconLoader = {}

local BASE        = "https://raw.githubusercontent.com/martin009gonzg-cmd/ICONOS/refs/heads/main/ICONOS/"
local ROOT_DIR    = "BLADEX/"
local CACHE_DIR   = ROOT_DIR .. "assets/"
local USED_FILE   = CACHE_DIR .. "used_icons.json"

local PACKAGE_FILES = {
    lucide    = "lucide",
    solar     = "solar",
    sfsymbols = "sfsymbols",
    gravity   = "gravity",
    swords    = "swords",
}

-- Lookup precalculado (minúsculas -> key real), evita iterar PACKAGE_FILES en cada llamada
local LOWER_TO_KEY = {}
for key in pairs(PACKAGE_FILES) do
    LOWER_TO_KEY[key:lower()] = key
end

local function resolvePackageName(name)
    if type(name) ~= "string" then return nil end
    return LOWER_TO_KEY[name:lower()]
end

-- Único punto de salida para avisos: error al cargar una textura/UID
local function reportTextureError(uid, msg)
    warn("[BLADEX] Error al cargar textura (UID: " .. tostring(uid) .. "): " .. tostring(msg))
end

pcall(function()
    if not isfolder(ROOT_DIR) then makefolder(ROOT_DIR) end
end)
pcall(function()
    if not isfolder(CACHE_DIR) then makefolder(CACHE_DIR) end
end)

-- ===================== Config =====================
local HTTP_TIMEOUT      = 15        -- segundos máximos por intento de HttpGet
local PACKAGE_CACHE_TTL = 24 * 3600 -- 24h antes de refrescar el caché de disco

local packageCache = {} -- caché en memoria (vive mientras el script esté cargado)
local lastError     = {}

local usedCache = nil

local function keyFor(pack, iconName) return pack .. "::" .. iconName end

local function loadUsedCacheFromDisk()
    if usedCache then return usedCache end
    usedCache = {}
    pcall(function()
        if isfile(USED_FILE) then
            local decoded = game:GetService("HttpService"):JSONDecode(readfile(USED_FILE))
            if type(decoded) == "table" then usedCache = decoded end
        end
    end)
    return usedCache
end

local function saveUsedCacheToDisk()
    pcall(function()
        writefile(USED_FILE, game:GetService("HttpService"):JSONEncode(usedCache or {}))
    end)
end

local function rememberUsedIcon(pack, iconName, assetId)
    loadUsedCacheFromDisk()
    local k = keyFor(pack, iconName)
    if usedCache[k] ~= assetId then
        usedCache[k] = assetId
        saveUsedCacheToDisk()
    end
end

-- ===================== Caché de paquetes en disco =====================
-- Evita re-descargar los paquetes completos cada vez que se reinyecta el script.

local function packageCacheFilePath(pack)
    return CACHE_DIR .. "pkg_" .. pack .. ".json"
end

local function savePackageToDisk(pack, icons)
    pcall(function()
        local payload = game:GetService("HttpService"):JSONEncode({
            timestamp = os.time(),
            icons     = icons,
        })
        writefile(packageCacheFilePath(pack), payload)
    end)
end

-- Devuelve icons si hay caché de disco válido (dentro del TTL), si no nil
local function loadPackageFromDisk(pack)
    local icons = nil
    pcall(function()
        local path = packageCacheFilePath(pack)
        if isfile(path) then
            local decoded = game:GetService("HttpService"):JSONDecode(readfile(path))
            if type(decoded) == "table" and type(decoded.icons) == "table" and type(decoded.timestamp) == "number" then
                if (os.time() - decoded.timestamp) <= PACKAGE_CACHE_TTL then
                    icons = decoded.icons
                end
            end
        end
    end)
    return icons
end

-- ===================== HTTP con timeout manual =====================
-- game:HttpGet es bloqueante y no soporta cancelación real, pero envolvemos la
-- espera para no colgar el hilo llamador indefinidamente si el servidor no responde.
local function httpGetWithTimeout(url, timeoutSec)
    timeoutSec = timeoutSec or HTTP_TIMEOUT
    local done, ok, result = false, false, nil

    task.spawn(function()
        ok, result = pcall(function() return game:HttpGet(url) end)
        done = true
    end)

    local waited, step = 0, 0.1
    while not done and waited < timeoutSec do
        task.wait(step)
        waited = waited + step
    end

    if not done then
        return false, "timeout — sin respuesta tras " .. timeoutSec .. "s"
    end
    return ok, result
end

local function safeHttpGet(url, attempts)
    attempts = attempts or 2
    local lastErr = nil
    for i = 1, attempts do
        local ok, result = httpGetWithTimeout(url, HTTP_TIMEOUT)
        if ok and result and #result > 0 then
            return true, result
        end
        lastErr = result
        if i < attempts then task.wait(1 * i) end
    end
    return false, lastErr
end

local function classifyError(errText)
    errText = tostring(errText or "")
    if errText:find("404") then
        return "NOT_FOUND (404) — el nombre del archivo no coincide (revisa mayúsculas en PACKAGE_FILES)."
    elseif errText:find("403") then
        return "403 — bloqueado temporalmente, reintenta en un momento."
    elseif errText:find("429") then
        return "429 — demasiadas peticiones a GitHub, espera un momento antes de reintentar."
    elseif errText:find("timeout") or errText:find("timed out") then
        return "TIMEOUT — sin respuesta, revisa tu conexión."
    elseif errText == "" then
        return "Respuesta vacía sin mensaje de error específico."
    else
        return "Error crudo: " .. errText
    end
end

local function fetchPackage(fileName)
    local url = BASE .. fileName
    local ok, content = safeHttpGet(url, 2)
    if not ok then
        return nil, classifyError(content)
    end

    local compiled, compileErr = loadstring(content)
    if not compiled then
        return nil, "El archivo se descargó pero no compiló como Lua: " .. tostring(compileErr)
    end

    local ok2, icons = pcall(compiled)
    if not ok2 then
        return nil, "El archivo compiló pero falló al ejecutarse: " .. tostring(icons)
    end
    if type(icons) ~= "table" or not next(icons) then
        return nil, "El archivo se ejecutó pero no devolvió una tabla de iconos válida."
    end

    return icons, nil
end

function IconLoader.LoadPackage(name, forceRefresh)
    local pack = resolvePackageName(name)
    if not pack then
        local valid = {}
        for k in pairs(PACKAGE_FILES) do table.insert(valid, k) end
        lastError[name] = "Paquete desconocido: '" .. tostring(name) .. "'. Válidos: " .. table.concat(valid, ", ")
        reportTextureError(name, lastError[name])
        return nil
    end

    if not forceRefresh and packageCache[pack] then return packageCache[pack] end

    if not forceRefresh then
        local diskIcons = loadPackageFromDisk(pack)
        if diskIcons then
            packageCache[pack] = diskIcons
            lastError[pack] = nil
            return diskIcons
        end
    end

    local icons, err = fetchPackage(PACKAGE_FILES[pack])
    if not icons then
        lastError[pack] = err or "Fallo desconocido."
        reportTextureError(pack, lastError[pack])
        return nil
    end

    packageCache[pack] = icons
    lastError[pack] = nil
    savePackageToDisk(pack, icons)
    return icons
end

function IconLoader.LoadPackages(names)
    local combined = {}
    for _, name in ipairs(names) do
        local icons = IconLoader.LoadPackage(name)
        if icons then
            for k, v in pairs(icons) do combined[k] = v end
        end
    end
    return combined
end

function IconLoader.Get(packName, iconName)
    local pack = resolvePackageName(packName)
    if not pack then return nil end

    loadUsedCacheFromDisk()
    local cached = usedCache[keyFor(pack, iconName)]
    if cached then return cached end

    local icons = IconLoader.LoadPackage(pack)
    if not icons then return nil end

    local assetId = icons[iconName]
    if assetId then
        rememberUsedIcon(pack, iconName, assetId)
    else
        reportTextureError(iconName, "El ícono '" .. tostring(iconName) .. "' no existe en el paquete '" .. pack .. "' (revisa el nombre).")
    end
    return assetId
end

function IconLoader.GetAny(packNames, iconName)
    for _, packName in ipairs(packNames) do
        local result = IconLoader.Get(packName, iconName)
        if result then return result, packName end
    end
    return nil
end

function IconLoader.Refresh(packName)
    return IconLoader.LoadPackage(packName, true)
end

function IconLoader.Diagnose(packName)
    local pack = resolvePackageName(packName) or packName
    return lastError[pack]
end

function IconLoader.ListPackages()
    local names = {}
    for k in pairs(PACKAGE_FILES) do table.insert(names, k) end
    table.sort(names)
    return names
end

function IconLoader.ListUsedIcons()
    loadUsedCacheFromDisk()
    local copy = {}
    for k, v in pairs(usedCache) do copy[k] = v end
    return copy
end

function IconLoader.ClearUsedCache()
    usedCache = {}
    pcall(function()
        if isfile(USED_FILE) then delfile(USED_FILE) end
    end)
end

return IconLoader
